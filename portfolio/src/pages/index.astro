---
// File: portfolio/src/pages/index.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import ExperienceCard from '@/components/ExperienceCard.astro';
import SkillTag from '@/components/SkillTag.astro';
import { skills, languages, education, experience, projects, involvement, awards, personal } from '@/data/cvData';
---
<BaseLayout title="M. Ahtisham Bhatti – AI Portfolio">
  <Header />

  <!-- About (short intro) -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-dark border-b-2 border-primary inline-block pb-1 mb-4">About Me</h2>
    <p class="text-light leading-relaxed">
      I'm an Artificial Intelligence student at Deggendorf Institute of Technology, passionate about building real‑world applications in AI, mobile development, and data analysis. I combine technical skills with cross‑cultural experience gained in Tanzania and Germany.
    </p>
  </section>

  <!-- Two‑column layout for main content and sidebar -->
  <div class="grid md:grid-cols-3 gap-8">
    <!-- Left column (2/3 width) -->
    <div class="md:col-span-2 space-y-10">
      <!-- Projects -->
      <section>
        <h2 class="text-2xl font-bold text-dark border-b-2 border-primary inline-block pb-1 mb-4">Featured Projects</h2>
        <div class="grid sm:grid-cols-2 gap-5">
          {projects.map(project => <ProjectCard project={project} />)}
        </div>
      </section>

      <!-- Experience -->
      <section>
        <h2 class="text-2xl font-bold text-dark border-b-2 border-primary inline-block pb-1 mb-4">Work Experience</h2>
        <div class="space-y-4">
          {experience.map(exp => <ExperienceCard item={exp} />)}
        </div>
      </section>

      <!-- Education -->
      <section>
        <h2 class="text-2xl font-bold text-dark border-b-2 border-primary inline-block pb-1 mb-4">Education</h2>
        <div class="space-y-5">
          {education.map(edu => (
            <div class="bg-white rounded-lg p-4 shadow-sm">
              <div class="flex flex-wrap justify-between items-baseline">
                <h3 class="text-lg font-bold text-dark">{edu.degree}</h3>
                <span class="text-xs text-light">{edu.period}</span>
              </div>
              <p class="text-primary text-sm">{edu.institution} – {edu.location}</p>
              {edu.details && <p class="text-light text-sm mt-2">{edu.details}</p>}
            </div>
          ))}
        </div>
      </section>

      <!-- Involvement (from comments) -->
      <section>
        <h2 class="text-2xl font-bold text-dark border-b-2 border-primary inline-block pb-1 mb-4">Involvement & Volunteering</h2>
        <div class="space-y-4">
          {involvement.map(vol => <ExperienceCard item={vol} />)}
        </div>
      </section>
    </div>

    <!-- Right column (1/3 width) – Skills, Languages, Awards -->
    <div class="space-y-8">
      <!-- Skills -->
      <section class="bg-white rounded-xl p-5 shadow-sm">
        <h3 class="text-xl font-bold text-dark mb-3 flex items-center gap-2">⚙️ Skills</h3>
        <div>
          {skills.map(skill => <SkillTag skill={skill} />)}
        </div>
      </section>

      <!-- Languages -->
      <section class="bg-white rounded-xl p-5 shadow-sm">
        <h3 class="text-xl font-bold text-dark mb-3 flex items-center gap-2">🌐 Languages</h3>
        <div class="space-y-2">
          {languages.map(lang => (
            <div>
              <div class="flex justify-between text-sm">
                <span class="font-medium">{lang.name}</span>
                <span class="text-light">{lang.level}</span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-2 mt-1">
                <div class="bg-primary h-2 rounded-full" style={`width: ${lang.score * 20}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Awards -->
      <section class="bg-white rounded-xl p-5 shadow-sm">
        <h3 class="text-xl font-bold text-dark mb-3 flex items-center gap-2">🏆 Awards</h3>
        <div class="space-y-3">
          {awards.map(award => (
            <div>
              <p class="font-semibold text-dark">{award.title}</p>
              <p class="text-xs text-light">{award.organization}, {award.date}</p>
              <p class="text-sm text-light mt-1">{award.description}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Quick contact / Download CV (placeholder) -->
      <section class="bg-white rounded-xl p-5 shadow-sm text-center">
        <h3 class="text-xl font-bold text-dark mb-2">📄 CV</h3>
        <p class="text-sm text-light mb-3">Full CV available on request or download a PDF version.</p>
        <a href="#" class="inline-block bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-dark transition">Download PDF (placeholder)</a>
      </section>
    </div>
  </div>

  <Footer />
</BaseLayout>