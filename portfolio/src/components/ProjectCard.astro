---
// File: portfolio/src/components/ProjectCard.astro
import type { Project } from '@/data/cvData';
const { project } = Astro.props as { project: Project };
---
<div class="bg-white rounded-xl shadow-md p-5 hover:shadow-lg transition-shadow border-l-4 border-primary">
  <h3 class="text-xl font-bold text-dark">{project.title}</h3>
  <p class="text-light mt-2 text-sm">{project.description}</p>
  {project.tech && (
    <div class="flex flex-wrap gap-2 mt-3">
      {project.tech.map(tech => <span class="text-xs bg-gray-100 text-dark px-2 py-1 rounded-full">{tech}</span>)}
    </div>
  )}
  {project.link && (
    <a href={project.link} target="_blank" rel="noopener noreferrer" class="inline-block mt-4 text-primary font-semibold text-sm hover:underline">
      {project.linkText || 'View Project'} →
    </a>
  )}
</div>