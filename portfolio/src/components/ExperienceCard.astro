---
// File: portfolio/src/components/ExperienceCard.astro
import type { Experience, Involvement } from '@/data/cvData';
const { item } = Astro.props as { item: Experience | Involvement };
---
<div class="bg-white rounded-lg p-4 shadow-sm border border-gray-100">
  <div class="flex flex-wrap justify-between items-baseline">
    <h3 class="text-lg font-bold text-dark">{item.title}</h3>
    <span class="text-xs text-light">{item.period}</span>
  </div>
  <p class="text-primary text-sm font-medium">{item.organization} – {item.location}</p>
  <ul class="list-disc list-inside mt-2 text-light text-sm space-y-1">
    {item.bullets.map(bullet => <li>{bullet}</li>)}
  </ul>
</div>